# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://soterion:password@localhost:5432/soterion

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / Security ──────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
API_KEY_SALT=change-me-to-a-random-32-char-string

# ── ML Service ───────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── AWS / S3 ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
